{
  "manifest_version": 3,
  "name": "Azure Tenant ID Finder",
  "version": "1.0.0",
  "description": "Look up the Azure AD Tenant ID for any domain instantly.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Azure Tenant ID Finder"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "host_permissions": [
    "https://login.microsoftonline.com/*"
  ]
}
